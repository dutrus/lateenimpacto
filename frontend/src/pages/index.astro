---
import { getOpportunities } from '../lib/db.js';
import '../styles/global.css';

const opportunities = await getOpportunities();

const categoryColors: Record<string, string> = {
  fellowship:   'bg-violet-100 text-violet-700',
  grant:        'bg-emerald-100 text-emerald-700',
  award:        'bg-amber-100 text-amber-700',
  competition:  'bg-rose-100 text-rose-700',
  scholarship:  'bg-sky-100 text-sky-700',
  program:      'bg-indigo-100 text-indigo-700',
};

function badgeClass(category: string | null) {
  if (!category) return 'bg-gray-100 text-gray-500';
  const key = category.toLowerCase();
  return categoryColors[key] ?? 'bg-gray-100 text-gray-500';
}

function formatDeadline(d: string | null) {
  if (!d) return null;
  return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function isExpiringSoon(d: string | null) {
  if (!d) return false;
  const diff = new Date(d).getTime() - Date.now();
  return diff > 0 && diff < 14 * 24 * 60 * 60 * 1000;
}
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>Lateen Impacto — Oportunidades</title>
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen">

  <!-- Header -->
  <header class="bg-white border-b border-gray-200 sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div>
        <h1 class="text-xl font-bold tracking-tight">Lateen Impacto</h1>
        <p class="text-xs text-gray-500 mt-0.5">Oportunidades de impacto social</p>
      </div>
      <span class="text-sm text-gray-400">{opportunities.length} oportunidades</span>
    </div>
  </header>

  <!-- Filter bar -->
  <div class="max-w-7xl mx-auto px-6 py-5">
    <div class="flex flex-wrap gap-2 mb-8" id="filter-bar">
      <button data-filter="all"
        class="filter-btn active px-3 py-1.5 rounded-full text-sm font-medium bg-gray-900 text-white transition">
        Todas
      </button>
      {[...new Set(opportunities.map(o => o.category).filter(Boolean))].sort().map(cat => (
        <button data-filter={cat}
          class={`filter-btn px-3 py-1.5 rounded-full text-sm font-medium border border-gray-200 bg-white text-gray-600 hover:bg-gray-100 transition ${badgeClass(cat)}`}>
          {cat!.charAt(0).toUpperCase() + cat!.slice(1)}
        </button>
      ))}
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="opp-grid">
      {opportunities.map(opp => (
        <article
          data-category={opp.category ?? ''}
          class="opp-card bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow flex flex-col overflow-hidden"
        >
          <!-- Card header accent -->
          <div class={`h-1 w-full ${
            opp.category === 'fellowship'  ? 'bg-violet-400' :
            opp.category === 'grant'       ? 'bg-emerald-400' :
            opp.category === 'award'       ? 'bg-amber-400' :
            opp.category === 'competition' ? 'bg-rose-400' :
            opp.category === 'scholarship' ? 'bg-sky-400' :
            opp.category === 'program'     ? 'bg-indigo-400' :
            'bg-gray-300'
          }`} />

          <div class="p-5 flex flex-col gap-3 flex-1">
            <!-- Category + deadline -->
            <div class="flex items-center justify-between gap-2 flex-wrap">
              {opp.category && (
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${badgeClass(opp.category)}`}>
                  {opp.category.charAt(0).toUpperCase() + opp.category.slice(1)}
                </span>
              )}
              {opp.deadline && (
                <span class={`text-xs font-medium flex items-center gap-1 ${isExpiringSoon(opp.deadline) ? 'text-rose-600' : 'text-gray-400'}`}>
                  {isExpiringSoon(opp.deadline) && <span class="inline-block w-1.5 h-1.5 rounded-full bg-rose-500" />}
                  {formatDeadline(opp.deadline)}
                </span>
              )}
            </div>

            <!-- Title -->
            <h2 class="font-semibold text-gray-900 text-base leading-snug line-clamp-3">
              {opp.title}
            </h2>

            <!-- Organization + LatAm badge -->
            <div class="flex items-center gap-2 flex-wrap">
              {opp.organization && (
                <p class="text-sm text-gray-500 font-medium">{opp.organization}</p>
              )}
              {opp.aplica_latam && (
                <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-green-100 text-green-700">
                  Latam 🌎
                </span>
              )}
            </div>

            <!-- Destination country + source -->
            <div class="flex items-center gap-3 text-xs text-gray-400 flex-wrap">
              {opp.pais_destino && (
                <span class="flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  {opp.pais_destino}
                </span>
              )}
              {opp.fuente && (
                <span class="truncate max-w-[160px]" title={opp.fuente}>
                  via {opp.fuente}
                </span>
              )}
            </div>

            <!-- AI-generated summary (falls back to nothing if not yet processed) -->
            {opp.resumen && (
              <p class="text-sm text-gray-600 leading-relaxed line-clamp-3 flex-1">
                {opp.resumen}
              </p>
            )}

            <!-- CTA -->
            {opp.link && (
              <a
                href={opp.link}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-auto pt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-gray-900 hover:text-violet-700 transition-colors group"
              >
                Ver convocatoria
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-20 text-gray-400">
      <p class="text-lg font-medium">No hay oportunidades en esta categoría.</p>
    </div>
  </div>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards   = document.querySelectorAll<HTMLElement>('.opp-card');
    const empty   = document.getElementById('empty-state')!;

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter ?? 'all';

        buttons.forEach(b => {
          b.classList.remove('bg-gray-900', 'text-white', 'active');
          b.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200');
        });
        btn.classList.add('bg-gray-900', 'text-white', 'active');
        btn.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200');

        let visible = 0;
        cards.forEach(card => {
          const match = filter === 'all' || card.dataset.category === filter;
          card.style.display = match ? '' : 'none';
          if (match) visible++;
        });

        empty.style.display = visible === 0 ? 'block' : 'none';
      });
    });
  </script>

</body>
</html>
